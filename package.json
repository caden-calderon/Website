{
  "name": "chromatic",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:full": "node scripts/dev-full.mjs",
    "measure:itop-browser": "node scripts/measure-itop-browser.mjs",
    "generate:test-ply": "node scripts/generate-test-ply.mjs",
    "generate:test-rgbd": "node scripts/generate-test-rgbd-sequence.mjs",
    "generate:test-kinect-bundle": "python3 -m python.kinect_capture.capture mock-bundle --output tmp/kinect-capture/kinect-rgbd-registration-smoke",
    "generate:test-kinect-rgbd": "python3 -m python.kinect_capture.capture mock-bundle --output tmp/kinect-capture/kinect-rgbd-registration-smoke && python3 -m python.kinect_capture.process export-rgbd --input-dir tmp/kinect-capture/kinect-rgbd-registration-smoke --output tmp/rgbd-sequences/kinect-rgbd-registration-smoke",
    "convert:itop": "python3 scripts/convert-itop-to-point-sequences.py",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/three": "^0.183.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-glsl": "^1.5.6",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@imgly/background-removal": "^1.7.0",
    "@threlte/core": "^8.5.0",
    "@threlte/extras": "^9.9.0",
    "three": "^0.183.2"
  }
}
